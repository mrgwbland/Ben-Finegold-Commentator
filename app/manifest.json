{
    "name": "Finegold Commentary for Lichess",
    "version": "1.0.0",
    "manifest_version": 3,
    "description": "Adds commentary to lichess.org (audio)",
    "icons": {
        "16": "images/icon-16.png",
        "128": "images/icon-128.png"
    },
    "default_locale": "en",
    "action": {
        "default_icon": "images/finegold.png",
        "default_title": "Finegold Commentary",
        "default_popup": "options.html"
    },
    "content_scripts": [
        {
            "matches": [
                "http://*.lichess.org/*",
                "https://*.lichess.org/*"
            ],
            "css": [],
            "js": [
                "vendor/webextension-polyfill/dist/browser-polyfill.min.js",
                "scripts/UserPrefs.js",
                "scripts/AudioUtils.js",
                "scripts/MutationUtils.js",
                "scripts/AudioQueue.js",
                "scripts/MoveEmitter.js",
                "scripts/GameStateEmitter.js",
                "scripts/finegoldlichess.js"
            ],
            "run_at": "document_idle",
            "all_frames": false
        }
    ],
    "web_accessible_resources": [
        {
          "resources": [
            "ogg/*"
          ],
          "matches": [
            "*://*/*"
          ]
        }
    ],
    "options_ui": {
        "page": "options.html"
    },
    "permissions": [
        "storage"
    ]
}
